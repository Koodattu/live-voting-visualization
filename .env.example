# Copy this file to .env. Use a long, unique value in production.
ADMIN_PASSWORD=replace-with-a-long-password

HOST=0.0.0.0
PORT=3000
PUBLIC_ORIGIN=http://localhost:3000
DATABASE_PATH=./data/live-voting.sqlite
BACKUP_DIR=./backups

# Optional IP address or CIDR of a trusted reverse proxy. Leave empty otherwise.
TRUST_PROXY=

# Keep true behind HTTPS. Set false only for local HTTP development.
COOKIE_SECURE=true
LOG_LEVEL=info
