{
  "name": "live-voting",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,client -c magenta,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run typecheck && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --exclude tests/load.test.ts",
    "test:watch": "vitest",
    "test:load": "vitest run tests/load.test.ts --testTimeout=30000"
  },
  "dependencies": {
    "@fastify/cookie": "11.1.1",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/static": "10.1.0",
    "better-sqlite3": "12.11.1",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "socket.io": "4.8.3",
    "socket.io-client": "4.8.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "tsx": "4.23.0",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
